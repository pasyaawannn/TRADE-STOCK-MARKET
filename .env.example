# ===== DATABASE =====
POSTGRES_USER=pasya
POSTGRES_PASSWORD=pasya_secret_change_this
POSTGRES_DB=pasya_db
DATABASE_URL=postgresql+asyncpg://pasya:pasya_secret_change_this@localhost:5432/pasya_db

# ===== REDIS =====
REDIS_PASSWORD=redis_secret_change_this
REDIS_URL=redis://:redis_secret_change_this@localhost:6379/0

# ===== JWT AUTH =====
JWT_SECRET=change-this-to-a-very-long-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== APP =====
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# ===== EXTERNAL DATA SOURCES =====
# IDX / Yahoo Finance (no key needed for yfinance)
# Uncomment and add key if using paid data provider
# IDX_API_KEY=your_key_here
# POLYGON_API_KEY=your_key_here
# ALPHA_VANTAGE_KEY=your_key_here

# ===== NEXT.JS =====
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXTAUTH_SECRET=change-this-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# ===== AI / OPENAI (Optional for AI insights) =====
# OPENAI_API_KEY=sk-your-key-here
